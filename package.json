{
  "name": "gaura_studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "dev": "vite",
    "build": "vite build && npm run format-html",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,html,scss,css,json}\"",
    "format-html": "prettier --write dist/**/*.html",
    "format:check": "prettier --check \"src/**/*.{js,html,scss,css,json}\"",
    "lint": "npm run lint:js && npm run lint:style",
    "lint:js": "eslint \"src/**/*.js\" --fix",
    "lint:js:check": "eslint \"src/**/*.js\"",
    "lint:style": "stylelint \"src/**/*.{css,scss}\" --fix",
    "lint:style:check": "stylelint \"src/**/*.{css,scss}\"",
    "lint:check": "npm run lint:js:check && npm run lint:style:check && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "autoprefixer": "^10.4.21",
    "css-declaration-sorter": "^7.3.0",
    "eslint": "^9.37.0",
    "fs": "^0.0.1-security",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "sass": "^1.93.2",
    "sharp": "^0.34.4",
    "stylelint": "^16.25.0",
    "stylelint-config-recess-order": "^7.3.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "svgo": "^4.0.0",
    "vite": "^7.1.9",
    "vite-plugin-handlebars": "^2.0.0",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-minify": "^2.1.0"
  },
  "dependencies": {
    "@vercel/edge": "^1.2.2",
    "aos": "^2.3.4",
    "gsap": "^3.13.0",
    "jquery": "^3.7.1",
    "particles.js": "^2.0.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "swiper": "^12.0.2"
  }
}
