{
  "name": "gaura_studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "dev": "vite",
    "build": "vite build && npm run format-html",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,html,scss,css,json}\"",
    "format-html": "prettier --write dist/**/*.html",
    "format:check": "prettier --check \"src/**/*.{js,html,scss,css,json}\"",
    "lint": "npm run lint:js && npm run lint:style",
    "lint:js": "eslint \"src/**/*.js\" --fix",
    "lint:js:check": "eslint \"src/**/*.js\"",
    "lint:style": "stylelint \"src/**/*.{css,scss}\" --fix",
    "lint:style:check": "stylelint \"src/**/*.{css,scss}\"",
    "lint:check": "npm run lint:js:check && npm run lint:style:check && npm run format:check"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "css-declaration-sorter": "^7.2.0",
    "eslint": "^8.57.0",
    "fs": "^0.0.1-security",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5",
    "sass": "^1.75.0",
    "sharp": "^0.33.3",
    "stylelint": "^16.6.1",
    "stylelint-config-recess-order": "^5.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "svgo": "^3.2.0",
    "vite": "^5.2.0",
    "vite-plugin-handlebars": "^2.0.0",
    "vite-plugin-image-optimizer": "^1.1.7",
    "vite-plugin-minify": "^1.5.2"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "gsap": "^3.12.5",
    "jquery": "^3.7.1",
    "particles.js": "^2.0.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "swiper": "^11.1.1"
  }
}
